# Credenciales de la cuenta de servicio IOL (InvertirOnline) usadas por la
# serverless function api/iol/cedears.js. Solo se leen del lado servidor.
#
# Uso local:  copiá este archivo a .env.local y completá los valores reales.
#             .env.local está gitignoreado — NUNCA se commitea.
# Producción: configurá estas mismas variables en Vercel
#             (Project Settings → Environment Variables → Production + Preview).

IOL_USERNAME=tu_usuario@ejemplo.com
IOL_PASSWORD=tu_password
