# Credenciales de MATRIZ provistas por Cohen (NO las de Cohen Connect).
# Cohen debe habilitar el acceso API (Primary/XOMS) en la cuenta comitente.
COHEN_USER=
COHEN_PASSWORD=
# Nro de comitente — opcional, NO se usa para órdenes (feed de solo lectura).
COHEN_ACCOUNT=
# Endpoints Primary del broker (default: Cohen). Para probar en sandbox
# reMarkets: https://api.remarkets.primary.com.ar/ y wss://api.remarkets.primary.com.ar/
COHEN_API_URL=https://api.cohen.xoms.com.ar/
COHEN_WS_URL=wss://api.cohen.xoms.com.ar/
PORT=8125
